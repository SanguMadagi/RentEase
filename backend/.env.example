# RentEase Backend Environment Variables
# Copy this file to .env or set these environment variables in your system

# Server Port
PORT=8080

# Database Configuration (MongoDB)
MONGODB_URI=mongodb://localhost:27017/rentease
MONGODB_DATABASE=rentease

# Email Configuration (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password

# OAuth2 Google Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Security Configurations
SECRET_KEY=your_base64_encoded_jwt_secret_key_at_least_256_bits_long

# Frontend Application URL
FRONTEND_URL=http://localhost:3000
